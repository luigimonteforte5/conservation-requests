# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mydatabase
DB_USER=myuser
DB_PASSWORD=your_secure_password_here

# Security Configuration
SECURITY_USER=admin
SECURITY_PASSWORD=your_bcrypt_hashed_admin_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_256_chars_recommended_here_make_it_very_long_and_complex
JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Encryption Configuration
ENCRYPTION_KEY=your_encryption_key_min_32_chars_here_make_it_very_secure

# Application Profiles
SPRING_PROFILES_ACTIVE=prod
